# one origin for the whole board: /ipfs/* to the Kubo gateway (media, served straight from IPFS),
# everything else to the board UI/API. a production deploy swaps this for a proxy with TLS + a real domain
:80 {
	handle /ipfs/* {
		header X-Content-Type-Options nosniff
		reverse_proxy kubo:8080
	}
	handle {
		reverse_proxy board:3000
	}
}

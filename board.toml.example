# Per-board customization. Copy to board.toml next to the binary, or point BAKEMONO_CONFIG at it.
# Every field is optional; a board with no file still boots. BAKEMONO_BOARD_NAME / _DMCA_CONTACT /
# _CONTACT env vars still work and win over the file, so existing deploys need no change.

name = "化け物 bakemono"
tagline = "a peer-to-peer content archive"

# Home mascot and welcome. mascot is any <img src>: a /static path (see static_dir), a data: URL, or a URL.
# welcome_html is rendered raw - it is operator-authored, same trust level as the binary, so links and
# basic markup are allowed. Shown on the home page above the recent grid.
mascot = "/static/mascot.png"
welcome_html = """
<p>Browse by <a href="/creators">creator</a> or jump into <a href="/posts">posts</a>.
Files are served from a peer swarm, nothing is stored on this box.</p>
"""

# Longer board description, rendered raw in an "About this board" block on /info.
about_html = """
<p>This board indexes signed manifests from the Bakemono network and serves previews from a peer swarm.
Read the <a href="/keepers">keepers</a> page to help keep content online.</p>
"""

# Optional accent override (defaults to Catppuccin mauve). Any CSS color.
accent = "#cba6f7"

# Serve operator assets (mascot, favicon) from this dir at /static/<file>, so the board makes no external
# request. Flat filenames only. With docker/deploy.sh, put the files in a ./static dir next to board.toml;
# deploy.sh ships it and mounts it at /config/static, so keep static_dir set to that path.
static_dir = "/config/static"

dmca_contact = "dmca@example.org"
contact = "hi@example.org"

# SEO. Set public_url to the board's real origin (no trailing slash) once it is on a public domain: it is
# the base for the canonical link, Open Graph tags and the sitemap, all of which need an absolute URL a
# crawler can trust. Unset = no canonical/OG/sitemap, and the booru API derives file links from the request.
# public_url = "https://board.example"

# Content rating reported to the booru API and, when questionable/explicit, emitted as <meta name="rating"
# content="adult"> so search engines file the board under SafeSearch instead of penalising it.
# rating = "explicit"

# Raw markup injected verbatim into every <head>. Meant for search-console verification meta tags; you can
# also verify by DNS and leave this unset. Operator-authored, same trust level as the binary.
# head_html = '<meta name="google-site-verification" content="..."><meta name="yandex-verification" content="...">'

# IndexNow key: any 8-128 char hex-ish string. Enables instant submission of new posts to Bing/Yandex (and,
# via Bing, DuckDuckGo) after each publish; the board serves it at /indexnow.txt for ownership verification.
# Google ignores IndexNow, so it stays on the sitemap + Search Console path. Unset = no IndexNow pings.
# indexnow_key = "0123456789abcdef0123456789abcdef"

# Community links shown in the footer. Add as many as you like.
[[community]]
label = "Telegram"
url = "https://t.me/yourboard"

[[community]]
label = "Discord"
url = "https://discord.gg/yourboard"

[[community]]
label = "Reddit"
url = "https://reddit.com/r/yourboard"

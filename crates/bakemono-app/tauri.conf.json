{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bakemono",
  "version": "0.3.0",
  "identifier": "org.bakemono.app",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "化け物 bakemono",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/bakemono-daemon",
      "binaries/gallery-dl",
      "binaries/ffmpeg"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bakemonoq/bakemono/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIzMTkwRDc4NTBCRUZBMzMKUldReityNVFlQTBac3h0Yk8ycERDVW91azNNMk9OK1VFVHM1OEtWQzBDVXRVWFRBczdneUFBbGUK"
    }
  }
}
